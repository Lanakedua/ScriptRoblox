-- ========== FUNGSI CARI FIELD ==========
local function FindField(fieldName)
    local folder = workspace:FindFirstChild("fields")
    if folder then
        for _, v in ipairs(folder:GetChildren()) do
            if v:IsA("BasePart") and v.Name == fieldName then
                return v.Position + Vector3.new(0, 5, 0)
            end
        end
    end
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("BasePart") and v.Name == fieldName then
            return v.Position + Vector3.new(0, 5, 0)
        end
    end
    return nil
end

-- ========== FUNGSI CARI HIVE PRIBADI ==========
local function FindMyHive()
    local honeycombs = workspace:FindFirstChild("Honeycombs")
    if not honeycombs then return nil end
    
    for _, hive in ipairs(honeycombs:GetChildren()) do
        if hive:IsA("Model") then
            for _, child in ipairs(hive:GetChildren()) do
                if child.Name == player.Name then
                    return hive
                end
            end
        end
    end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == player.Name and obj.Parent then
            local parent = obj.Parent
            if parent.Parent and parent.Parent.Name == "Honeycombs" then
                return parent
            end
        end
    end
    
    return nil
end

-- ========== TELEPORT ==========
local function Teleport(fieldName)
    local pos = FindField(fieldName)
    if not pos then return false end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end
    player.Character.HumanoidRootPart.CFrame = CFrame.new(pos)
    return true
end

-- ========== TELEPORT KE HIVE ==========
local function TeleportToMyHive()
    local myHive = FindMyHive()
    if not myHive then return false end
    
    for _, part in ipairs(myHive:GetChildren()) do
        if part:IsA("BasePart") then
            local pos = part.Position + Vector3.new(0, 5, 0)
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end
            player.Character.HumanoidRootPart.CFrame = CFrame.new(pos)
            
            task.wait(0.3)
            
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                firetouchinterest(player.Character.HumanoidRootPart, part, 0)
                firetouchinterest(player.Character.HumanoidRootPart, part, 1)
            end
            
            -- Coba remote claimHive
            local remoteEvents = replicatedStorage:FindFirstChild("remoteEvents")
            if remoteEvents then
                local claimHive = remoteEvents:FindFirstChild("claimHive")
                if claimHive then
                    claimHive:FireServer()
                end
            end
            
            return true
        end
    end
    
    return false
end

-- ========== SPEED & JUMP VARIABEL ==========
local speedEnabled = true
local targetSpeed = 50
local targetJump = 100
local speedConnection = nil

-- ========== FUNGSI ANTI RESET (HEARTBEAT - 60X/DETIK) ==========
local function StartAntiReset()
    if speedConnection then
        speedConnection:Disconnect()
    end
    
    speedConnection = RunService.Heartbeat:Connect(function()
        if not speedEnabled then return end
        
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            local hum = char.Humanoid
            
            -- Force speed setiap frame
            if hum.WalkSpeed ~= targetSpeed then
                hum.WalkSpeed = targetSpeed
            end
            
            -- Force jump setiap frame
            if hum.JumpPower ~= targetJump then
                hum.JumpPower = targetJump
                hum.UseJumpPower = true
            end
        end
    end)
end

local function StopAntiReset()
    if speedConnection then
        speedConnection:Disconnect()
        speedConnection = nil
    end
    -- Balikin ke normal
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 16
        char.Humanoid.JumpPower = 50
    end
end

